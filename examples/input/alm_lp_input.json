{
  "metadata": {
    "case_id": "alm_demo_001",
    "description": "Minimal ALM linear programming demo with input-defined constraints and objective."
  },
  "variables": [
    {
      "name": "asset_short_bond",
      "lb": 0,
      "ub": 80
    },
    {
      "name": "asset_medium_loan",
      "lb": 0,
      "ub": 80
    },
    {
      "name": "short_term_funding",
      "lb": 0,
      "ub": 30
    }
  ],
  "constraints": [
    {
      "name": "balance_equation",
      "lb": 100,
      "ub": 100,
      "terms": [
        {
          "var": "asset_short_bond",
          "coef": 1
        },
        {
          "var": "asset_medium_loan",
          "coef": 1
        },
        {
          "var": "short_term_funding",
          "coef": -1
        }
      ]
    },
    {
      "name": "liquidity_floor",
      "lb": 45,
      "ub": null,
      "terms": [
        {
          "var": "asset_short_bond",
          "coef": 0.7
        },
        {
          "var": "asset_medium_loan",
          "coef": 0.2
        }
      ]
    },
    {
      "name": "duration_exposure_cap",
      "lb": null,
      "ub": 430,
      "terms": [
        {
          "var": "asset_short_bond",
          "coef": 2
        },
        {
          "var": "asset_medium_loan",
          "coef": 5
        }
      ]
    },
    {
      "name": "funding_limit",
      "lb": null,
      "ub": 30,
      "terms": [
        {
          "var": "short_term_funding",
          "coef": 1
        }
      ]
    }
  ],
  "objective": {
    "sense": "max",
    "terms": [
      {
        "var": "asset_short_bond",
        "coef": 0.055
      },
      {
        "var": "asset_medium_loan",
        "coef": 0.072
      },
      {
        "var": "short_term_funding",
        "coef": -0.04
      }
    ],
    "constant": 0
  }
}
